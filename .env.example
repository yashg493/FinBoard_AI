# Boardroom AI — Environment Variables
# Copy this to .env and fill in your values

# ─── Google Cloud ─────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS=./credentials/gcp-key.json
VERTEX_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1

# ─── MongoDB Atlas ────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/boardroom-ai?retryWrites=true&w=majority

# ─── Firebase Auth ────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─── Arize Phoenix Observability ──────────────
ARIZE_SPACE_KEY=
ARIZE_API_KEY=

# ─── WebSocket URLs ───────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:8000/ws
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Optional: External Data APIs ────────────
ALPHA_VANTAGE_API_KEY=       # Market data
FRED_API_KEY=                # US Federal Reserve data
NEWS_API_KEY=                # Financial news
